{
  "name": "writehabit-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "node src/index.js",
    "dev:watch": "nodemon --watch src src/index.js",
    "start": "node src/index.js",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "seed:keywords": "node prisma/seed-keywords.js",
    "db:seed": "node prisma/seed.js",
    "push:daily": "node scripts/send-daily-keyword.js",
    "test": "node --test 'test/**/*.test.js'"
  },
  "dependencies": {
    "@parse/node-apn": "^8.1.0",
    "@prisma/client": "^6.18.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "nodemon": "^3.1.10",
    "prisma": "^6.18.0",
    "supertest": "^7.2.2"
  }
}
